{
  "name": "aklump/directio",
  "type": "library",
  "version": "0.0.0",
  "autoload": {
    "psr-4": {
      "AKlump\\Directio\\": "src/"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.intheloftstudios.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "symfony/console": "^5.4",
    "symfony/serializer": "^5.4",
    "symfony/property-access": "^5.4",
    "aklump/local-timezone": "^0.0.1",
    "doctrine/lexer": "^2.1",
    "aklump/fixture-framework": "^0.0.10"
  },
  "license": "BSD-3-Clause",
  "bin": [
    "./directio"
  ],
  "autoload-dev": {
    "psr-4": {
      "AKlump\\Directio\\Tests\\Unit\\": "./tests_unit"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "ext-json": "*"
  }
}
